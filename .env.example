# ============================================================
# The Christian Project — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Required ---

# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# --- Optional: Model Selection ---

# GPT model used for generating responses (default: gpt-4o-mini)
# Use gpt-4o for higher quality at higher cost.
OPENAI_COMPLETIONS_MODEL=gpt-4o-mini

# --- Optional: Generation Tuning ---

# Maximum tokens in the AI's response (default: 1024)
MAX_TOKENS=1024

# Response creativity — 0.0 is deterministic, 1.0 is more varied (default: 0.7)
TEMPERATURE=0.7

# --- Optional: Rate Limiting ---

# Max queries per user per minute to prevent abuse and control API costs (default: 20)
RATE_LIMIT_PER_MIN=20

# --- Optional: Infrastructure ---

# Port for the Streamlit server (default: 8501, Railway sets this automatically)
PORT=8501

# Path to the review queue file for logging unanswered questions (default: data/metrics/review_queue.jsonl)
REVIEW_QUEUE_PATH=data/metrics/review_queue.jsonl

# Auto-training confidence threshold — responses below this score are queued for review (default: 0.75)
AUTO_TRAIN_THRESHOLD=0.75

# HuggingFace model cache location (default: data/cache)
HF_HOME=data/cache
